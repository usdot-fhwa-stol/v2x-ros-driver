<launch>

    <!-- Declare Launch Arguments -->
    <arg name="log_level" default="WARN" 
         description="The log level to use for the v2x_ros_driver_node"/>
         
    <arg name="configuration_delay" default="2.0" 
         description="The delay in seconds before the v2x_ros_driver_node is configured"/>
         
    <arg name="enable_v2x_driver_lifecycle" default="False" 
         description="Enable the v2x_ros_driver_node lifecycle. If enabled manually transitions the node to active state. Default is false"/>
         
    <arg name="protocol" default="udp" 
         description="Communication protocol: 'udp' for Cohda/Commsignia/Kapsch, 'mqtt' for Ettifos OBU"/>
         
    <arg name="global_params_override_file" default="/opt/carma/vehicle/config/GlobalParamsOverride.yaml" 
         description="Path to global file containing the parameters overwrite"/>

    <!-- Launch node(s) in a carma container to allow logging to be configured -->
    <node_container pkg="carma_ros2_utils" exec="carma_component_container_mt" name="v2x_ros_driver_container" on_exit="shutdown">
        
        <!-- Launch the core node(s) -->
        <composable_node pkg="v2x_ros_driver" plugin="V2XDriverApplication::Node" name="v2x_ros_driver_node">
            
            <!-- Extra Arguments -->
            <extra_arg name="use_intra_process_comms" value="True"/>
            <extra_arg name="--log-level" value="$(var log_level)"/>

            <!-- Remappings -->
            <remap from="inbound_binary_msg" to="comms/inbound_binary_msg"/>
            <remap from="outbound_binary_msg" to="comms/outbound_binary_msg"/>

            <!-- Parameters -->
            <param from="$(find-pkg-share v2x_ros_driver)/config/params.yaml"/>
            <param from="$(var global_params_override_file)"/>
            
            <!-- Protocol can be overridden from the command line. -->
            <param name="protocol" value="$(var protocol)"/>
        </composable_node>
        
    </node_container>

    <!-- Node lifecycle activation called only if enable_v2x_driver_lifecycle is set to true -->
    <group if="$(var enable_v2x_driver_lifecycle)">
        <!-- 
          Using a shell execution chain to handle the sequenced event:
          Wait for configuration_delay, then configure, then activate.
        -->
        <executable cmd="sh -c 'sleep $(var configuration_delay) &amp;&amp; ros2 lifecycle set /v2x_ros_driver_node configure &amp;&amp; ros2 lifecycle set /v2x_ros_driver_node activate'" output="screen" />
    </group>

</launch>